<controls:ProWindow x:Class="UmojoParkingPoC.DockPanes.SignInWindow"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:controls="clr-namespace:ArcGIS.Desktop.Framework.Controls;assembly=ArcGIS.Desktop.Framework"
                    xmlns:extensions="clr-namespace:ArcGIS.Desktop.Extensions;assembly=ArcGIS.Desktop.Extensions"
                    xmlns:local="clr-namespace:UmojoParkingPoC.DockPanes"
                    mc:Ignorable="d"
                    Title="Sign in to Umojo"
                    Height="240" Width="360"
                    WindowStartupLocation="CenterOwner"
                    ResizeMode="NoResize"
                    d:DataContext="{d:DesignInstance Type=local:SignInWindowViewModel}">
    <controls:ProWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <extensions:DesignOnlyResourceDictionary Source="pack://application:,,,/ArcGIS.Desktop.Framework;component\Themes\Default.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        </ResourceDictionary>
    </controls:ProWindow.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Username" VerticalAlignment="Center" Margin="0,0,8,6"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="UsernameBox"
                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,6"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Password" VerticalAlignment="Center" Margin="0,0,8,6"/>
        <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="PasswordBox" Margin="0,0,0,6"/>

        <ProgressBar Grid.Row="2" Grid.ColumnSpan="2" Height="4" IsIndeterminate="True"
                     Margin="0,4,0,4"
                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <TextBlock Grid.Row="3" Grid.ColumnSpan="2"
                   Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource Esri_RedBrush}"
                   TextWrapping="Wrap"
                   Margin="0,2,0,2"/>

        <TextBlock Grid.Row="4" Grid.ColumnSpan="2"
                   Text="Authenticating..."
                   Foreground="{DynamicResource Esri_TextStyleDisabledBrush}"
                   VerticalAlignment="Center"
                   Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Cancel" MinWidth="80" Margin="0,0,8,0" IsCancel="True"/>
            <Button x:Name="SignInButton"
                    Content="Sign In" MinWidth="80" IsDefault="True"
                    Click="OnSignInClick"
                    Style="{DynamicResource Esri_ButtonDefault}"/>
        </StackPanel>
    </Grid>
</controls:ProWindow>
